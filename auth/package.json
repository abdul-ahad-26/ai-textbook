{
  "name": "ai-textbook-auth",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Better-Auth server for the Physical AI textbook (signup captures SW/HW background).",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
