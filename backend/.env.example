# ===== Backend environment (copy to .env and fill in) =====

# --- OpenAI (Agents SDK + ChatKit + embeddings) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# --- Qdrant Cloud (free tier) ---
QDRANT_URL=https://YOUR-CLUSTER.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=physical_ai_book

# --- Neon Serverless Postgres ---
# From the Neon dashboard -> Connection string (use the pooled "-pooler" host).
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# --- CORS: where the book + auth server are served from ---
# Add your GitHub Pages origin too, e.g. https://you.github.io
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
